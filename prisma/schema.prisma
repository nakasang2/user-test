generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// 認証・マルチテナント
// ─────────────────────────────────────────────

model Organization {
  id         String      @id @default(cuid())
  name       String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  users      User[]
  interviews Interview[]
  members    Member[]
  invites    Invite[]
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  name           String
  passwordHash   String
  role           String       @default("owner") // legacy – 実際の権限は Member.role を参照
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships    Member[]
  createdInvites Invite[]     @relation("InviteCreatedBy")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// 組織×ユーザーの多対多（将来の複数組織対応も見据えた junction table）
model Member {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           String       @default("viewer") // owner | admin | editor | viewer
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([userId, organizationId])
}

// 招待トークン（メール or リンク共有）
model Invite {
  id             String       @id @default(cuid())
  token          String       @unique @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User         @relation("InviteCreatedBy", fields: [createdById], references: [id])
  email          String?      // 特定メールのみ有効にする場合
  role           String       @default("viewer") // viewer | editor | admin
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime     @default(now())
}

// ─────────────────────────────────────────────
// インタビュー
// ─────────────────────────────────────────────

model Interview {
  id               String        @id @default(cuid())
  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id])
  title            String
  description      String?
  type             String        @default("interview") // interview | impression | prototype | usability
  stimulusUrl      String?       // impression: image URL, prototype: Figma embed URL
  stimulusDuration Int?          // impression test: seconds to display (default 5)
  questions        Question[]
  sessions         Session[]
  tasks            Task[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Question {
  id          String    @id @default(cuid())
  text        String
  order       Int
  type        String    @default("open") // open | rating | nps
  interviewId String
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
}

model Task {
  id          String    @id @default(cuid())
  interviewId String
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  text        String
  order       Int
}

model Participant {
  id        String    @id @default(cuid())
  name      String
  email     String?
  sessions  Session[]
  createdAt DateTime  @default(now())
}

model Session {
  id            String          @id @default(cuid())
  interviewId   String
  participantId String?
  dailyRoomName String          @unique
  dailyRoomUrl  String
  status        String          @default("pending")
  recordingId   String?
  recordingUrl  String?
  transcript    Transcript?
  emotions      EmotionResult[]
  interview     Interview       @relation(fields: [interviewId], references: [id])
  participant   Participant?    @relation(fields: [participantId], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Transcript {
  id        String              @id @default(cuid())
  sessionId String              @unique
  session   Session             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  fullText  String
  segments  TranscriptSegment[]
  summary   String?
  themes    String?
  createdAt DateTime            @default(now())
}

model TranscriptSegment {
  id           String     @id @default(cuid())
  transcriptId String
  transcript   Transcript @relation(fields: [transcriptId], references: [id], onDelete: Cascade)
  speaker      String
  text         String
  startTime    Float
  endTime      Float
  sentiment    String?
}

model EmotionResult {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  timestamp Float
  happy     Float    @default(0)
  sad       Float    @default(0)
  angry     Float    @default(0)
  fearful   Float    @default(0)
  disgusted Float    @default(0)
  surprised Float    @default(0)
  neutral   Float    @default(0)
  createdAt DateTime @default(now())
}
